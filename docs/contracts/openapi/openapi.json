  "components": {
    "schemas": {
      "AdsRequest": {
        "properties": {
          "client_id": {
            "type": "string",
            "title": "Client Id"
          },
          "campaign_objective": {
            "type": "string",
            "title": "Campaign Objective"
          },
          "platform": {
            "type": "string",
            "title": "Platform"
          },
          "offer_description": {
            "type": "string",
            "title": "Offer Description"
          },
          "tone": {
            "type": "string",
            "title": "Tone",
            "default": "urgencia"
          },
          "audience_override": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Audience Override"
          }
        },
        "type": "object",
        "required": [
          "client_id",
          "campaign_objective",
          "platform",
          "offer_description"
        ],
        "title": "AdsRequest"
      },
      "ApproveStepRequest": {
        "properties": {
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "title": "ApproveStepRequest"
      },
      "CalendarRequest": {
        "properties": {
          "client_id": {
            "type": "string",
            "title": "Client Id"
          },
          "month": {
            "type": "string",
            "title": "Month"
          },
          "frequency": {
            "type": "string",
            "title": "Frequency",
            "default": "3x/semana"
          },
          "platforms": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Platforms",
            "default": [
              "Instagram"
            ]
          },
          "monthly_objective": {
            "type": "string",
            "title": "Monthly Objective",
            "default": ""
          },
          "pillar_mode": {
            "type": "string",
            "title": "Pillar Mode",
            "default": "auto"
          },
          "custom_pillars": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Custom Pillars"
          }
        },
        "type": "object",
        "required": [
          "client_id",
          "month"
        ],
        "title": "CalendarRequest"
      },
      "CopyRequest": {
        "properties": {
          "client_id": {
            "type": "string",
            "title": "Client Id"
          },
          "campaign_description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Campaign Description"
          },
          "persona_focus": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Persona Focus"
          },
          "output_format": {
            "type": "string",
            "title": "Output Format",
            "default": "structured"
          }
        },
        "type": "object",
        "required": [
          "client_id"
        ],
        "title": "CopyRequest"
      },
      "CreateWorkflowRunRequest": {
        "properties": {
          "client_id": {
            "type": "string",
            "title": "Client Id"
          },
          "task_type": {
            "type": "string",
