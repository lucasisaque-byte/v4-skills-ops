  "cssVariables": "/* KCE Logistics — Design Tokens · v1.0.0 · 2026-03-24 */\n/* Cole em :root { } no seu CSS principal */\n\n/* === CORES === */\n--color-primary:         #F15A22;\n--color-primary-light:   #F69B79;\n--color-primary-lighter: #FDE2D9;\n--color-primary-dark:    #99310A;\n\n--color-secondary:       #1C2336;\n--color-secondary-dark:  #191C24;\n\n--color-white:           #FFFFFF;\n--color-black:           #000000;\n--color-gray-50:         #F9FAFB;\n--color-gray-100:        #F3F4F6;\n--color-gray-200:        #E5E7EB;\n--color-gray-400:        #9CA3AF;\n--color-gray-600:        #4B5563;\n--color-gray-700:        #2C333C;\n\n--color-text:            #191C24;\n--color-text-secondary:  #5E6E8D;\n--color-text-muted:      #4B5563;\n--color-text-inverse:    #FFFFFF;\n--color-text-accent:     #F15A22;\n\n--color-bg:              #FFFFFF;\n--color-bg-subtle:       #F3F4F6;\n--color-bg-dark:         #1C2336;\n--color-bg-darker:       #191C24;\n--color-bg-accent:       #F15A22;\n\n/* === TIPOGRAFIA === */\n--font-primary:          'Roboto', Arial, Helvetica, sans-serif;\n\n--font-size-display:     4rem;\n--font-size-h1:          3rem;\n--font-size-h2:          2.5rem;\n--font-size-h3:          1.75rem;\n--font-size-h4:          1.5rem;\n--font-size-body-lg:     1.125rem;\n--font-size-body:        1rem;\n--font-size-body-sm:     0.875rem;\n--font-size-caption:     0.75rem;\n\n--font-weight-light:     300;\n--font-weight-regular:   400;\n--font-weight-medium:    500;\n--font-weight-semibold:  600;\n--font-weight-bold:      700;\n--font-weight-extrabold: 800;\n--font-weight-black:     900;\n\n/* === ESPAÇAMENTO === */\n--spacing-base:          8px;\n--section-padding-y:     96px;\n--container-max:         1370px;\n--container-padding-x:   20px;\n\n/* === BORDAS === */\n--radius-button:         4px;\n--radius-card:           8px;\n--radius-card-lg:        12px;\n--radius-container:      8px;"
