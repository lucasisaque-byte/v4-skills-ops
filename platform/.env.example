# Copie para .env.local e preencha (servidor Next; nunca NEXT_PUBLIC_* para segredos)
# WORKFLOW_API_TOKEN deve ser idêntico ao da API FastAPI.

WORKFLOW_API_TOKEN=
PLATFORM_SESSION_SECRET=

# Opcional: URL absoluta do FastAPI (recomendado em produção)
# WORKFLOW_API_UPSTREAM_URL=https://seu-backend.up.railway.app

# NEXT_PUBLIC_API_URL= fallback se WORKFLOW_API_UPSTREAM_URL não estiver definido
