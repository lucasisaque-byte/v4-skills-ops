# Copie este arquivo para .env e preencha os valores
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (opcional — necessário apenas se usar modelos gemini-*)
# GOOGLE_API_KEY=AIza...

# Modelo padrão (pode ser trocado por claude-opus-4-6 para máxima qualidade, ou gemini-2.0-flash para menor custo)
MODEL=claude-sonnet-4-6

# Limite de tokens por resposta
MAX_TOKENS=8096

# Autenticação workflow (obrigatório em produção na API). Mesmo valor em platform/.env.local
# como WORKFLOW_API_TOKEN. Gere com: openssl rand -hex 32
WORKFLOW_API_TOKEN=

# Só desenvolvimento local: permite API sem token (nunca em produção)
# WORKFLOW_AUTH_ALLOW_MISSING=1

# CORS — origens permitidas no browser (CSV). Sem isso: produção usa v4-skills-ops.vercel.app, dev usa *.
# CORS_ALLOWED_ORIGINS=https://v4-skills-ops.vercel.app,https://meu-dominio.com
